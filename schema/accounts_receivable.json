{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Production-Grade Accounts Receivable (AR)",
  "description": "Enterprise-ready AR schema with tax, audit, and global reporting fields.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "invoice_id",
      "customer_id",
      "invoice_date",
      "due_date",
      "base_amount",
      "tax_amount",
      "total_amount",
      "currency",
      "status",
      "source_system",
      "created_at"
    ],
    "properties": {
      "invoice_id": { "type": "string" },
      "customer_id": { "type": "string" },
      "customer_name": { "type": "string" },
      "revenue_stream": {
        "type": "string",
        "enum": ["ADVERTISING", "SYNDICATION", "DISTRIBUTION", "SPONSORSHIP"]
      },
      "invoice_date": { "type": "string", "format": "date" },
      "due_date": { "type": "string", "format": "date" },
      "contracted_payment_terms": { "type": "integer" },
      "base_amount": { "type": "number", "description": "Net amount before tax." },
      "tax_amount": { "type": "number", "description": "VAT/GST/Sales Tax amount." },
      "total_amount": { "type": "number", "description": "Gross amount (Base + Tax)." },
      "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
      "reporting_currency_code": { "type": "string", "pattern": "^[A-Z]{3}$" },
      "reporting_currency_total_amount": { "type": "number" },
      "exchange_rate": { "type": "number" },
      "status": {
        "type": "string",
        "enum": ["OPEN", "PARTIALLY_PAID", "PAID", "OVERDUE", "DISPUTED", "WRITTEN_OFF"]
      },
      "historical_avg_payment_days": { "type": "integer" },
      "source_system": { "type": "string" },
      "created_at": { "type": "string", "format": "date-time" },
      "updated_at": { "type": "string", "format": "date-time" },
      "version": { "type": "integer" }
    }
  }
}